# ─── DMP OS Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your credentials before running the server.

# ── Supabase (PostgreSQL) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── FINRA API ─────────────────────────────────────────────────────────────────
# OAuth 2.0 credentials from FINRA Gateway (https://gateway.finra.org)
FINRA_CLIENT_ID=your_finra_client_id
FINRA_CLIENT_SECRET=your_finra_client_secret
# Set to "qa" for FINRA QA test environment, "prod" for production
FINRA_ENV=qa

# ── OpenAI (for LLM gap analysis) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Storj (S3-compatible document storage) ────────────────────────────────────
STORJ_ACCESS_KEY=your_storj_access_key
STORJ_SECRET_KEY=your_storj_secret_key
STORJ_BUCKET=dmp-wsp-documents
STORJ_ENDPOINT=https://gateway.storjshare.io

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
